---
import siteData from '../data/site-data.json';
import { useTranslations } from '../i18n/utils';
import '../styles/templatemo-personal-style.css';

const { profile, projects, socialLinks } = siteData;
const currentYear = new Date().getFullYear();

// Detectar el idioma (por defecto 'en' en la raíz)
const t = useTranslations('es'); // Forzamos español por ahora o detectamos
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="googlee460e4cf88b4d148" />
    
    <!-- Primary Meta Tags -->
    <title>{profile.nombre} - {profile.profesion} | Portfolio</title>
    <meta name="title" content="{profile.nombre_completo} - {profile.titulo_profesional} | Portfolio">
    <meta name="description" content="{profile.descripcion_breve || 'Desarrollador Full Stack especializado en tecnologías modernas. Explora mi portfolio y experiencia profesional.'}">
    <meta name="keywords" content="desarrollador, programador, portfolio, {profile.habilidades_principales || 'JavaScript, Python, React, Node.js'}, {profile.ubicacion}">
    <meta name="robots" content="index, follow">
    <meta name="language" content="Spanish">
    <meta name="author" content="{profile.nombre_completo}">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://Brun0West.github.io/Brun0West/">
    <meta property="og:title" content="{profile.nombre_completo} - {profile.titulo_profesional} | Portfolio">
    <meta property="og:description" content="{profile.descripcion_breve || 'Desarrollador Full Stack especializado en tecnologías modernas. Explora mi portfolio y experiencia profesional.'}">
    <meta property="og:image" content="https://Brun0West.github.io/Brun0West/images/profile-photo.jpg">
    <meta property="og:locale" content="es_ES">
    <meta property="og:site_name" content="{profile.nombre_completo} - Portfolio">
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://Brun0West.github.io/Brun0West/">
    <meta property="twitter:title" content="{profile.nombre_completo} - {profile.titulo_profesional} | Portfolio">
    <meta property="twitter:description" content="{profile.descripcion_breve || 'Desarrollador Full Stack especializado en tecnologías modernas. Explora mi portfolio y experiencia profesional.'}">
    <meta property="twitter:image" content="https://Brun0West.github.io/Brun0West/images/profile-photo.jpg">
    
    <!-- Additional SEO -->
    <meta name="theme-color" content="#2563eb">
    <link rel="canonical" href="https://Brun0West.github.io/Brun0West/">
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "{profile.nombre_completo}",
      "jobTitle": "{profile.titulo_profesional}",
      "url": "https://Brun0West.github.io/Brun0West/",
      "sameAs": [
        "{socialLinks?.linkedin}",
        "{socialLinks?.github}",
        "{socialLinks?.twitter || ''}"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Freelance"
      }
    }
    </script>
</head>
<body>
    <!-- Navigation -->
    <nav id="navbar">
        <div class="nav-container">
            <div class="logo">{profile.apodo}</div>
            <ul class="nav-links">
                <li><a href="#home">{t('nav.home')}</a></li>
                <li><a href="#about">{t('nav.about')}</a></li>
                <li><a href="#portfolio">{t('nav.portfolio')}</a></li>
                <li><a href="#contact">{t('nav.contact')}</a></li>
            </ul>
            <div class="mobile-menu-toggle" id="mobileMenuToggle">
                <div class="hamburger"></div>
                <div class="hamburger"></div>
                <div class="hamburger"></div>
            </div>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobileMenu">
        <ul class="mobile-nav-links">
            <li><a href="#home">{t('nav.home')}</a></li>
            <li><a href="#about">{t('nav.about')}</a></li>
            <li><a href="#portfolio">{t('nav.portfolio')}</a></li>
            <li><a href="#contact">{t('nav.contact')}</a></li>
        </ul>
    </div>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="floating-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
            <div class="shape shape-4"></div>
            <div class="shape shape-5"></div>
            <div class="shape shape-6"></div>
        </div>
        <div class="hero-content">
            <div class="hero-subtitle">{profile.profesion}</div>
            <h1>{profile.nombre}</h1>
            <p class="subtitle">{profile.loQueHago}</p>
            <a href="#portfolio" class="cta-button">{t('hero.explore')}</a>
        </div>
        <div class="scroll-indicator"></div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2 class="section-title fade-in">{t('about.title')}</h2>
            <div class="about-content">
                <img id="profile-image" class="about-image slide-in-left" src={profile.imagen} alt={profile.nombre}>
                <div class="about-text slide-in-right">
                    <h3>{profile.acercaDeMi}</h3>
                    <p>{profile.descripcion}</p>
                    <div class="social-links-container">
                        {socialLinks.map((social) => (
                            <a href={social.link} target="_blank" rel="noopener noreferrer" class="social-btn">
                                <img src={social.logo} alt={social.redSocial} class="social-logo" />
                                <span>{social.redSocial}</span>
                            </a>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Portfolio Section -->
    <section id="portfolio" class="portfolio">
        <div class="container">
            <h2 class="section-title fade-in">{t('portfolio.title')}</h2>
            <div class="portfolio-grid">
                {projects.map((project) => (
                <div class="portfolio-item">
                    {project.imagen && <img src={project.imagen} alt="" class="portfolio-image" />}
                    <div class="portfolio-content">
                        <h4>{project.nombre}</h4>
                        <p>{project.description}</p>
                        <div class="portfolio-tech">
                            {project.tecnologias.map((tecnologia) => (
                                <span class="tech-tag">{tecnologia}</span>
                            ))}
                        </div>
                    </div>
                </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="contact-floating-shapes">
            <div class="contact-shape contact-shape-1"></div>
            <div class="contact-shape contact-shape-2"></div>
            <div class="contact-shape contact-shape-3"></div>
            <div class="contact-shape contact-shape-4"></div>
            <div class="contact-shape contact-shape-5"></div>
            <div class="contact-shape contact-shape-6"></div>
        </div>
        <div class="container">
            <div class="contact-content">
                <h2 class="section-title fade-in">{t('contact.title')}</h2>
                <p class="fade-in">{t('contact.desc')}</p>
                
                {/* Formulario de contacto - Usando un servicio externo como Formspree para estático */}
                <form class="contact-form fade-in" action="https://formspree.io/f/xzdznzna" method="POST">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="name">{t('form.name')}</label>
                            <input type="text" id="name" name="name" placeholder={t('form.name_placeholder')} required>
                        </div>
                        <div class="form-group">
                            <label for="email">{t('form.email')}</label>
                            <input type="email" id="email" name="email" placeholder={t('form.email_placeholder')} required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="subject">{t('form.subject')}</label>
                        <input type="text" id="subject" name="subject" placeholder={t('form.subject_placeholder')} required>
                    </div>
                    <div class="form-group">
                        <label for="message">{t('form.message')}</label>
                        <textarea id="message" name="message" rows="6" placeholder={t('form.message_placeholder')} required></textarea>
                    </div>
                    <button type="submit" class="submit-btn">{t('form.send')}</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-left">
                    <p>&copy; {currentYear} {t('footer.rights')}</p>
                </div>
                <!-- <div class="footer-right">
                    <a href="#privacy">{t('footer.privacy')}</a>
                    <a href="#terms">{t('footer.terms')}</a>
                    <a href="#sitemap">{t('footer.sitemap')}</a>
                </div> -->
            </div>
        </div>
    </footer>

    <script src="../scripts/templatemo-personal-javascripts.js"></script>
</body>
</html>
